<file path="src/components/three/ParticleField.tsx">
import { useRef, useMemo } from 'react'
import { useFrame } from '@react-three/fiber'
import { useScroll } from 'motion/react'
import * as THREE from 'three'
import { useReducedMotion } from '@/hooks/useReducedMotion'

const COUNT = 4000

// Deterministic pseudo-random number generator to satisfy React purity rules
// This ensures the component remains purely idempotent while generating random-looking distributions
function pseudoRandom(seed: number): number {
  const x = Math.sin(seed * 12.9898 + 78.233) * 43758.5453
  return x - Math.floor(x)
}

// Simple noise function (no external dependency)
function noise3D(x: number, y: number, z: number): number {
  return (
    Math.sin(x * 1.2 + y * 0.8) *
    Math.cos(y * 1.1 + z * 0.9) *
    Math.sin(z * 1.3 + x * 0.7)
  )
}

export function ParticleField() {
  const prefersReducedMotion = useReducedMotion()
  const pointsRef = useRef<THREE.Points>(null!)
  const materialRef = useRef<THREE.PointsMaterial>(null!)
  const { scrollYProgress } = useScroll()

  // Generate initial positions (sphere) and colors
  const { positions, colors, basePositions } = useMemo(() => {
    const positions = new Float32Array(COUNT * 3)
    const basePositions = new Float32Array(COUNT * 3)
    const colors = new Float32Array(COUNT * 3)

    const lapis = new THREE.Color('#5b8def')
    const gold = new THREE.Color('#eab308')

    for (let i = 0; i < COUNT; i++) {
      // Sphere distribution using deterministic pseudo-random numbers
      const theta = pseudoRandom(i) * Math.PI * 2
      const phi = Math.acos(2 * pseudoRandom(i + 10000) - 1)
      const r = 3 + pseudoRandom(i + 20000) * 1.5

      const x = r * Math.sin(phi) * Math.cos(theta)
      const y = r * Math.sin(phi) * Math.sin(theta)
      const z = r * Math.cos(phi)

      positions[i * 3] = x
      positions[i * 3 + 1] = y
      positions[i * 3 + 2] = z

      basePositions[i * 3] = x
      basePositions[i * 3 + 1] = y
      basePositions[i * 3 + 2] = z

      // Color gradient based on position
      const t = (y + 5) / 10 // normalize y to 0-1
      const color = lapis.clone().lerp(gold, t)
      colors[i * 3] = color.r
      colors[i * 3 + 1] = color.g
      colors[i * 3 + 2] = color.b
    }

    return { positions, colors, basePositions }
  }, [])

  useFrame((state) => {
    if (prefersReducedMotion || !pointsRef.current) return

    const time = state.clock.elapsedTime
    const scroll = scrollYProgress.get()

    // Smooth rotation based on time + scroll
    pointsRef.current.rotation.y = time * 0.08 + scroll * Math.PI * 1.5
    pointsRef.current.rotation.x = Math.sin(time * 0.05) * 0.15

    // Update positions with noise + scroll morph
    const posArray = pointsRef.current.geometry.attributes.position
      .array as Float32Array

    for (let i = 0; i < COUNT; i++) {
      const i3 = i * 3
      const bx = basePositions[i3]
      const by = basePositions[i3 + 1]
      const bz = basePositions[i3 + 2]

      // Noise displacement
      const noiseScale = 0.3
      const noiseStrength = 0.4 + scroll * 0.3
      const nx =
        noise3D(bx * noiseScale, by * noiseScale, time * 0.3) * noiseStrength
      const ny =
        noise3D(by * noiseScale, bz * noiseScale, time * 0.3) * noiseStrength
      const nz =
        noise3D(bz * noiseScale, bx * noiseScale, time * 0.3) * noiseStrength

      // Scroll-based expansion (particles spread out as you scroll)
      const expansion = 1 + scroll * 0.8

      posArray[i3] = bx * expansion + nx
      posArray[i3 + 1] = by * expansion + ny
      posArray[i3 + 2] = bz * expansion + nz
    }

    pointsRef.current.geometry.attributes.position.needsUpdate = true

    // Size pulsation based on scroll
    if (materialRef.current) {
      materialRef.current.size = 0.04 + scroll * 0.03
      materialRef.current.opacity = 0.7 - scroll * 0.3
    }
  })

  if (prefersReducedMotion) return null

  return (
    <points ref={pointsRef}>
      <bufferGeometry>
        <bufferAttribute
          attach="attributes-position"
          args={[positions, 3]}
          count={COUNT}
        />
        <bufferAttribute
          attach="attributes-color"
          args={[colors, 3]}
          count={COUNT}
        />
      </bufferGeometry>
      <pointsMaterial
        ref={materialRef}
        size={0.04}
        vertexColors
        transparent
        opacity={0.7}
        blending={THREE.AdditiveBlending}
        sizeAttenuation
        depthWrite={false}
      />
    </points>
  )
}
